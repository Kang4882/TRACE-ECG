# Copy this file to paths.env and edit for your machine.

# Path to a GEM checkout after applying scripts/apply_gem_patch.sh.
export GEM_ROOT="${GEM_ROOT:-/path/to/GEM}"
export TRACE_ECG_ROOT="${TRACE_ECG_ROOT:-/path/to/TRACE-ECG}"

export GEMLIKE_DATA_ROOT="${GEMLIKE_DATA_ROOT:-/data/ecg_l3_gemlike_v1}"
export CLEAN1008_DATA_ROOT="${CLEAN1008_DATA_ROOT:-/data/ecg_l3_clean_1008}"
export ECG_FOLDER="${ECG_FOLDER:-/data/ecg_timeseries}"

export LANSG_GEM_CHECKPOINT="${LANSG_GEM_CHECKPOINT:-/data/model_checkpoints/LANSG_GEM}"
export GEM_RECIPE_INIT_CHECKPOINT="${GEM_RECIPE_INIT_CHECKPOINT:-/data/model_checkpoints/liuhaotian_llava-v1.6-vicuna-7b}"
export ECG_TOWER="${ECG_TOWER:-${GEM_ROOT}/ecg_coca/open_clip/checkpoint/cpt_wfep_epoch_20.pt}"
export VISION_TOWER="${VISION_TOWER:-openai/clip-vit-large-patch14-336}"

export OUTPUT_ROOT="${OUTPUT_ROOT:-/data/model_checkpoints/trace_ecg_experiments}"
export HF_HOME="${HF_HOME:-/data/download_cache/hf}"
export CONDA_ENV="${CONDA_ENV:-gem}"
