+def _normalize_non_lora_key(key):
+    if key.startswith('base_model.'):
+        key = key[11:]
+    if key.startswith('model.model.'):
+        key = key[6:]
+    return key.replace('.base_layer.', '.')
+
+
+def _apply_lora_adapter_scale(model, scale):
+    if scale is None:
+        return
+    scale = float(scale)
+    if scale == 1.0:
+        return
+    scaled = 0
+    for module in model.modules():
+        scaling = getattr(module, "scaling", None)
+        if isinstance(scaling, dict):
+            for adapter_name in list(scaling.keys()):
+                scaling[adapter_name] = scaling[adapter_name] * scale
+                scaled += 1
+    print(f"Applied LoRA adapter scale={scale} to {scaled} adapter scaling entries before merge.")
+
