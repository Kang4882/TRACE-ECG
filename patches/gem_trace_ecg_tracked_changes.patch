+def write_pure_lora_audit(model, training_args, audit_info, *, stage: str, non_lora_state_dict=None):
+    if not (training_args.local_rank == 0 or training_args.local_rank == -1):
+        return
+    if not getattr(training_args, "pure_lora_protocol", False):
+        return
+
+    trainable_params, total_params = count_trainable_parameters(model)
+    trainable_names = [name for name, parameter in model.named_parameters() if parameter.requires_grad]
+    lora_names = [name for name in trainable_names if "lora_" in name]
+    unexpected_trainable = [name for name in trainable_names if "lora_" not in name]
+    unexpected_lora = [name for name in lora_names if not _is_allowed_pure_lora_name(name)]
+    projector_base_trainable = [
+        name for name, parameter in model.named_parameters()
+        if parameter.requires_grad and ("ecg_projector" in name or "mm_projector" in name) and "lora_" not in name
+    ]
+    non_lora_keys = list((non_lora_state_dict or {}).keys())
+    non_lora_projector_keys = [
+        key for key in non_lora_keys
+        if "ecg_projector" in key or "mm_projector" in key
+    ]
+    payload = {
+        "stage": stage,
+        "pure_lora_protocol": True,
+        "lora_target_modules_arg": getattr(training_args, "lora_target_modules", None),
+        "expected_protocol": "LLM self-attn q/k/v/o LoRA + mm_projector.0/.2 LoRA only",
+        "trainable_params": int(trainable_params),
+        "total_params": int(total_params),
+        "trainable_percent": float(100.0 * trainable_params / max(total_params, 1)),
+        "trainable_module_names": trainable_names,
+        "lora_module_names": lora_names,
+        "llm_lora_module_names": (audit_info or {}).get("llm_lora_names", []),
+        "mm_projector_lora_module_names": (audit_info or {}).get("mm_projector_lora_names", []),
+        "frozen_projector_base_names": (audit_info or {}).get("frozen_projector_base_names", []),
+        "unexpected_trainable_names": unexpected_trainable,
+        "unexpected_lora_names": unexpected_lora,
+        "projector_base_trainable_names": projector_base_trainable,
+        "non_lora_trainables_key_count": len(non_lora_keys),
+        "non_lora_projector_keys": non_lora_projector_keys,
+        "status": "PASS" if not unexpected_trainable and not unexpected_lora and not projector_base_trainable and not non_lora_projector_keys else "FAIL",
+    }
+    os.makedirs(training_args.output_dir, exist_ok=True)
+    json_path = os.path.join(training_args.output_dir, "pure_lora_audit.json")
+    md_path = os.path.join(training_args.output_dir, "pure_lora_audit.md")
+    with open(json_path, "w", encoding="utf-8") as handle:
+        json.dump(payload, handle, indent=2, ensure_ascii=False)
+        handle.write("\n")
+    lines = [
+        "# Pure LoRA Audit",
+        "",
+        f"PURE_LORA_AUDIT_STATUS = {payload['status']}",
+        "",
+        f"- stage: `{stage}`",
+        f"- trainable params: `{trainable_params:,}` / `{total_params:,}` (`{payload['trainable_percent']:.3f}%`)",
+        f"- LoRA module count: `{len(lora_names)}`",
+        f"- unexpected trainable non-LoRA params: `{len(unexpected_trainable)}`",
+        f"- unexpected LoRA params: `{len(unexpected_lora)}`",
+        f"- trainable projector base params: `{len(projector_base_trainable)}`",
+        f"- non_lora_trainables projector keys: `{len(non_lora_projector_keys)}`",
+        "",
+        "## Trainable Modules",
+        "",
+    ]
+    lines.extend(f"- `{name}`" for name in trainable_names[:500])
+    if len(trainable_names) > 500:
+        lines.append(f"- ... truncated, total `{len(trainable_names)}`")
+    with open(md_path, "w", encoding="utf-8") as handle:
+        handle.write("\n".join(lines) + "\n")
