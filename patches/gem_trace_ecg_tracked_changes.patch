+def _anchor_ecg_info(sample: Dict[str, Any], data_args: DataArguments) -> Dict[str, Any]:
+    metadata = dict(sample.get("metadata") or {})
+    candidates = _answer_candidates_from_metadata(metadata)
+    candidate_max = getattr(data_args, "anchor_ecg_candidate_max", None)
+    if candidate_max is not None and int(candidate_max) > 0:
+        candidates = candidates[: int(candidate_max)]
+    target_idx = metadata.get("target_candidate_idx", metadata.get("target_answer_id", -1))
+    try:
+        target_idx = int(target_idx)
+    except (TypeError, ValueError):
+        target_idx = -1
+    bind_eligible = _to_bool(metadata.get("bind_eligible", sample.get("bind_eligible")))
+    strict = bool(getattr(data_args, "anchor_ecg_strict_eligibility", True))
+    valid = bool(candidates) and len(candidates) >= 2 and 0 <= target_idx < len(candidates)
+    eligible = valid and (bind_eligible or not strict)
+    skip_reason = None
+    if not bind_eligible and strict:
+        skip_reason = "bind_eligible_false"
+    elif len(candidates) < 2:
+        skip_reason = "candidate_count_lt_2"
+    elif target_idx < 0 or target_idx >= len(candidates):
+        skip_reason = "invalid_target_candidate_idx"
+    elif not valid:
+        skip_reason = "invalid_bind_metadata"
+    return {
+        "anchor_ecg_active_eligible": bool(eligible),
+        "candidate_answer_strings": candidates,
+        "target_answer_index": target_idx if valid else -1,
+        "answer_space_size": len(candidates) if valid else 0,
+        "skip_reason": skip_reason,
+        "train_group_id": metadata.get("train_group_id"),
+        "render_group_key": metadata.get("render_group_key"),
+        "layout_name": metadata.get("layout_name") or metadata.get("layout"),
+    }
