+        data_args = self._triplet_data_args()
+        bind_losses = []
+        margin_losses = []
+        target_scores = []
+        best_wrong_scores = []
+        margins = []
+        num_groups = int(group_answer_space_size.numel())
+        for group_idx in range(num_groups):
+            if group_eligible is not None and not bool(group_eligible[group_idx].detach().cpu().item()):
+                continue
+            answer_space_size = int(group_answer_space_size[group_idx].detach().cpu().item())
+            target_idx = int(group_target_answer_index[group_idx].detach().cpu().item())
+            if answer_space_size < 2 or target_idx < 0:
+                continue
+            layout_scores = []
+            complete = True
+            for layout_idx in range(group_size):
+                mask = (candidate_group_index == group_idx) & (candidate_layout_index == layout_idx)
+                if int(mask.sum().detach().cpu().item()) != answer_space_size:
+                    complete = False
+                    break
+                scores = torch.empty(answer_space_size, device=candidate_scores.device, dtype=candidate_scores.dtype)
+                selected_scores = candidate_scores[mask]
+                selected_answer_indices = candidate_answer_index[mask]
+                for score, answer_idx in zip(selected_scores, selected_answer_indices):
+                    scores[int(answer_idx.detach().cpu().item())] = score
+                layout_scores.append(scores)
+            if not complete:
+                continue
+            scores_by_layout = torch.stack(layout_scores, dim=0)
+            bind_loss, margin_loss = compute_targetbind_margin_losses(
+                scores_by_layout,
+                target_idx,
+                alpha=float(getattr(data_args, "layoutbind_alpha", 0.5)),
+                label_smoothing=float(getattr(data_args, "layoutbind_label_smoothing", 0.05)),
+                margin_delta=float(getattr(data_args, "layoutbind_margin_delta", 0.5)),
+            )
+            bind_losses.append(bind_loss)
+            margin_losses.append(margin_loss)
+            wrong_mask = torch.ones(answer_space_size, device=scores_by_layout.device, dtype=torch.bool)
+            wrong_mask[target_idx] = False
+            target_score = scores_by_layout[:, target_idx]
+            best_wrong_score = scores_by_layout[:, wrong_mask].max(dim=1).values
+            margin = target_score - best_wrong_score
+            target_scores.append(target_score)
+            best_wrong_scores.append(best_wrong_score)
+            margins.append(margin)
+
+        if bind_losses:
+            bind_loss = torch.stack(bind_losses).mean()
+            margin_loss = torch.stack(margin_losses).mean()
+            all_target_scores = torch.cat(target_scores)
+            all_best_wrong_scores = torch.cat(best_wrong_scores)
+            all_margins = torch.cat(margins)
+            margin_delta = float(getattr(data_args, "layoutbind_margin_delta", 0.5))
+            stats = {
+                "target_score_mean": all_target_scores.mean(),
+                "best_wrong_score_mean": all_best_wrong_scores.mean(),
+                "target_margin_mean": all_margins.mean(),
+                "target_margin_positive_rate": all_margins.gt(0).float().mean(),
+                "target_margin_negative_rate": all_margins.lt(0).float().mean(),
+                "margin_violation_rate": all_margins.lt(margin_delta).float().mean(),
+                "kl_bind_loss_mean": bind_loss.detach(),
+                "layoutbind_eligible_groups_in_batch": float(len(bind_losses)),
+            }
+            return bind_loss, margin_loss, stats
+        zero = candidate_scores.sum() * 0.0
+        return zero, zero, {
+            "target_score_mean": zero.detach(),
+            "best_wrong_score_mean": zero.detach(),
+            "target_margin_mean": zero.detach(),
+            "target_margin_positive_rate": zero.detach(),
+            "target_margin_negative_rate": zero.detach(),
+            "margin_violation_rate": zero.detach(),
+            "kl_bind_loss_mean": zero.detach(),
+            "layoutbind_eligible_groups_in_batch": 0.0,
+        }
+
+    def _anchor_ecg_margin_loss(
+        self,
+        candidate_scores,
+        *,
+        candidate_row_index,
+        candidate_answer_index,
+        row_eligible,
+        row_target_answer_index,
+        row_answer_space_size,
+    ):
+        data_args = self._triplet_data_args()
+        margin_delta = float(getattr(data_args, "anchor_ecg_margin_delta", 0.5))
+        margin_losses = []
+        target_scores = []
+        best_wrong_scores = []
+        margins = []
+        eligible_rows = 0
+        incomplete_rows = 0
+        num_rows = int(row_answer_space_size.numel())
+        for row_idx in range(num_rows):
+            if row_eligible is not None and not bool(row_eligible[row_idx].detach().cpu().item()):
+                continue
+            answer_space_size = int(row_answer_space_size[row_idx].detach().cpu().item())
+            target_idx = int(row_target_answer_index[row_idx].detach().cpu().item())
+            if answer_space_size < 2 or target_idx < 0 or target_idx >= answer_space_size:
+                continue
+            mask = candidate_row_index == row_idx
+            if int(mask.sum().detach().cpu().item()) != answer_space_size:
+                incomplete_rows += 1
+                continue
+            scores = torch.full(
+                (answer_space_size,),
+                -torch.inf,
+                device=candidate_scores.device,
+                dtype=candidate_scores.dtype,
+            )
+            selected_scores = candidate_scores[mask]
+            selected_answer_indices = candidate_answer_index[mask]
+            for score, answer_idx in zip(selected_scores, selected_answer_indices):
+                scores[int(answer_idx.detach().cpu().item())] = score
+            wrong_mask = torch.ones(answer_space_size, device=scores.device, dtype=torch.bool)
+            wrong_mask[target_idx] = False
+            target_score = scores[target_idx]
+            best_wrong_score = scores[wrong_mask].max()
+            margin = target_score - best_wrong_score
+            margin_losses.append(F.relu(torch.as_tensor(margin_delta, device=scores.device, dtype=scores.dtype) - margin))
+            target_scores.append(target_score.reshape(1))
+            best_wrong_scores.append(best_wrong_score.reshape(1))
+            margins.append(margin.reshape(1))
+            eligible_rows += 1
+
+        if margin_losses:
+            margin_loss = torch.stack(margin_losses).mean()
+            all_target_scores = torch.cat(target_scores)
+            all_best_wrong_scores = torch.cat(best_wrong_scores)
+            all_margins = torch.cat(margins)
+            stats = {
+                "anchor_target_score_mean": all_target_scores.mean(),
+                "anchor_best_wrong_score_mean": all_best_wrong_scores.mean(),
+                "anchor_target_margin_mean": all_margins.mean(),
+                "anchor_target_margin_positive_rate": all_margins.gt(0).float().mean(),
+                "anchor_target_margin_negative_rate": all_margins.lt(0).float().mean(),
+                "anchor_margin_violation_rate": all_margins.lt(margin_delta).float().mean(),
+                "anchor_eligible_rows_in_batch": float(eligible_rows),
+                "anchor_incomplete_rows_in_batch": float(incomplete_rows),
+            }
+            return margin_loss, stats
+
+        zero = candidate_scores.sum() * 0.0
+        return zero, {
+            "anchor_target_score_mean": zero.detach(),
+            "anchor_best_wrong_score_mean": zero.detach(),
+            "anchor_target_margin_mean": zero.detach(),
+            "anchor_target_margin_positive_rate": zero.detach(),
+            "anchor_target_margin_negative_rate": zero.detach(),
+            "anchor_margin_violation_rate": zero.detach(),
+            "anchor_eligible_rows_in_batch": 0.0,
+            "anchor_incomplete_rows_in_batch": float(incomplete_rows),
+        }
+
+    def _write_anchor_debug_row(
+        self,
+        *,
+        loss,
+        ce_loss,
+        margin_loss,
+        weighted_margin,
+        base_count,
+        candidate_count,
+        skipped_count,
+        extra_metrics,
+    ):
+        csv_path = os.environ.get("ANCHOR_ECG_TRAIN_LOG_CSV") or os.environ.get("TRIPLET_TRAIN_LOG_CSV")
+        if not csv_path:
+            return
+        rank = self._triplet_rank()
+        if rank != 0:
+            root, ext = os.path.splitext(csv_path)
+            csv_path = f"{root}.rank{rank}{ext or '.csv'}"
+        os.makedirs(os.path.dirname(csv_path), exist_ok=True)
+        if not hasattr(self, "_anchor_debug_start_time"):
+            self._anchor_debug_start_time = time.time()
+            self._anchor_debug_micro_step = 0
+            self._anchor_debug_base_rows = 0
+            self._anchor_debug_candidate_rows = 0
+        self._anchor_debug_micro_step += 1
+        self._anchor_debug_base_rows += int(base_count)
+        self._anchor_debug_candidate_rows += int(candidate_count)
+        max_allocated_gb = torch.cuda.max_memory_allocated() / (1024 ** 3) if torch.cuda.is_available() else 0.0
+        reserved_gb = torch.cuda.memory_reserved() / (1024 ** 3) if torch.cuda.is_available() else 0.0
+        row = {
+            "time_iso": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
+            "elapsed_sec": f"{time.time() - self._anchor_debug_start_time:.3f}",
+            "optimizer_step": int(self.state.global_step),
+            "micro_step": int(self._anchor_debug_micro_step),
+            "rank": rank,
+            "total_loss": f"{float(loss.detach().float().cpu()):.8f}",
+            "CE_all": f"{float(ce_loss.detach().float().cpu()):.8f}",
+            "L_TargetMargin_bind_raw": f"{float(margin_loss.detach().float().cpu()):.8f}",
+            "weighted_TargetMargin_bind": f"{float(weighted_margin.detach().float().cpu()):.8f}",
+            "base_rows_this_microstep": int(base_count),
+            "candidate_rows_this_microstep": int(candidate_count),
+            "anchor_rows_skipped_this_microstep": int(skipped_count),
+            "base_rows_cumulative": int(self._anchor_debug_base_rows),
+            "candidate_rows_cumulative": int(self._anchor_debug_candidate_rows),
+            "rank_max_memory_allocated_gb": f"{max_allocated_gb:.3f}",
+            "rank_memory_reserved_gb": f"{reserved_gb:.3f}",
+        }
+        for key, value in (extra_metrics or {}).items():
+            if torch.is_tensor(value):
+                if value.numel() == 1:
+                    value = value.detach().float().cpu().item()
+                else:
+                    value = value.detach().float().cpu().tolist()
+            if isinstance(value, float):
+                row[key] = f"{value:.8f}"
+            else:
+                row[key] = value
+        header = list(row.keys())
+        write_header = not os.path.exists(csv_path) or os.path.getsize(csv_path) == 0
+        with open(csv_path, "a", encoding="utf-8") as f:
+            if write_header:
+                f.write(",".join(header) + "\n")
+            f.write(",".join(str(row[key]) for key in header) + "\n")
+
+    def _compute_anchor_ecg_rowwise_loss(self, model, inputs, return_outputs=False, **kwargs):
+        base_count_tensor = inputs.pop("anchor_ecg_base_count", None)
+        candidate_count_tensor = inputs.pop("anchor_ecg_candidate_count", None)
+        candidate_row_index = inputs.pop("anchor_ecg_candidate_row_index", None)
+        candidate_answer_index = inputs.pop("anchor_ecg_candidate_answer_index", None)
+        row_eligible = inputs.pop("anchor_ecg_row_eligible", None)
+        row_target_answer_index = inputs.pop("anchor_ecg_row_target_answer_index", None)
+        row_answer_space_size = inputs.pop("anchor_ecg_row_answer_space_size", None)
+        skipped_tensor = inputs.pop("anchor_ecg_rows_skipped", None)
+
+        candidate_count = int(candidate_count_tensor.detach().cpu().item()) if torch.is_tensor(candidate_count_tensor) else int(candidate_count_tensor or 0)
+        if candidate_count <= 0:
+            return super().compute_loss(model, inputs, return_outputs=return_outputs, **kwargs)
+        if base_count_tensor is None:
+            raise ValueError("TargetMargin row-wise loss requires anchor_ecg_base_count.")
+        base_count = int(base_count_tensor.detach().cpu().item()) if torch.is_tensor(base_count_tensor) else int(base_count_tensor)
+        skipped_count = int(skipped_tensor.detach().cpu().item()) if torch.is_tensor(skipped_tensor) else int(skipped_tensor or 0)
+        data_args = self._triplet_data_args()
+        length_normalize = bool(getattr(data_args, "anchor_ecg_length_normalize", True))
+
+        outputs, logits, expanded_labels = self._forward_with_expanded_labels(model, inputs)
+        sequence_count = int(expanded_labels.shape[0])
+        if sequence_count != base_count + candidate_count:
+            raise ValueError(
+                f"TargetMargin expected {base_count + candidate_count} flattened examples "
+                f"({base_count} base + {candidate_count} candidates), got {sequence_count}."
+            )
+        ce_loss = self._token_ce_loss_from_logits(logits[:base_count], expanded_labels[:base_count])
+        candidate_losses = self._sequence_losses_from_logits_with_normalization(
+            logits[base_count:],
+            expanded_labels[base_count:],
+            length_normalize=length_normalize,
+        )
+        candidate_scores = -candidate_losses
+        margin_loss, stats = self._anchor_ecg_margin_loss(
+            candidate_scores,
+            candidate_row_index=candidate_row_index,
+            candidate_answer_index=candidate_answer_index,
+            row_eligible=row_eligible,
+            row_target_answer_index=row_target_answer_index,
+            row_answer_space_size=row_answer_space_size,
+        )
+        lambda_margin = float(getattr(data_args, "anchor_ecg_lambda_margin", 0.05))
+        weighted_margin = lambda_margin * margin_loss
+        loss = ce_loss + weighted_margin
+        self._write_anchor_debug_row(
+            loss=loss,
+            ce_loss=ce_loss,
+            margin_loss=margin_loss,
+            weighted_margin=weighted_margin,
+            base_count=base_count,
+            candidate_count=candidate_count,
+            skipped_count=skipped_count,
+            extra_metrics={
+                "anchor_ecg_lambda_margin": lambda_margin,
+                "anchor_ecg_margin_delta": float(getattr(data_args, "anchor_ecg_margin_delta", 0.5)),
+                "anchor_ecg_length_normalize": int(length_normalize),
+                **stats,
+            },
+        )
+        return (loss, outputs) if return_outputs else loss
+
+    def _anchor_ecg_backward(self, loss: torch.Tensor) -> None:
+        if self.args.n_gpu > 1:
+            loss = loss.mean()
+        if self.use_apex:
+            raise RuntimeError("TargetMargin memory-safe backward does not support Apex AMP.")
+        self.accelerator.backward(loss)
+
+    def _anchor_ecg_zero_trainable_loss(self, model) -> torch.Tensor:
+        zero = None
+        for param in model.parameters():
+            if not param.requires_grad:
+                continue
+            term = param.reshape(-1)[0] * 0.0
+            zero = term if zero is None else zero + term
+        if zero is None:
+            raise RuntimeError("TargetMargin memory-safe backward found no trainable parameters.")
+        return zero
+
+    def _anchor_ecg_memory_safe_training_step(self, model, inputs) -> torch.Tensor:
+        model.train()
+        inputs = self._prepare_inputs(inputs)
+        if is_sagemaker_mp_enabled():
+            raise RuntimeError("TargetMargin memory-safe backward does not support SageMaker model parallel.")
+
+        with self.compute_loss_context_manager():
+            base_count_tensor = inputs.pop("anchor_ecg_base_count", None)
+            candidate_count_tensor = inputs.pop("anchor_ecg_candidate_count", None)
+            candidate_row_index = inputs.pop("anchor_ecg_candidate_row_index", None)
+            candidate_answer_index = inputs.pop("anchor_ecg_candidate_answer_index", None)
+            row_eligible = inputs.pop("anchor_ecg_row_eligible", None)
+            row_target_answer_index = inputs.pop("anchor_ecg_row_target_answer_index", None)
+            row_answer_space_size = inputs.pop("anchor_ecg_row_answer_space_size", None)
+            skipped_tensor = inputs.pop("anchor_ecg_rows_skipped", None)
+
+            candidate_count = int(candidate_count_tensor.detach().cpu().item()) if torch.is_tensor(candidate_count_tensor) else int(candidate_count_tensor or 0)
+            if base_count_tensor is None:
+                loss = super().compute_loss(model, inputs)
+                self._anchor_ecg_backward(loss)
+                return loss.detach() / self.args.gradient_accumulation_steps
+
+            base_count = int(base_count_tensor.detach().cpu().item()) if torch.is_tensor(base_count_tensor) else int(base_count_tensor)
+            skipped_count = int(skipped_tensor.detach().cpu().item()) if torch.is_tensor(skipped_tensor) else int(skipped_tensor or 0)
+            data_args = self._triplet_data_args()
+            length_normalize = bool(getattr(data_args, "anchor_ecg_length_normalize", True))
+            lambda_margin = float(getattr(data_args, "anchor_ecg_lambda_margin", 0.05))
+            chunk_bind_rows = int(getattr(data_args, "anchor_ecg_margin_chunk_bind_rows", 2) or 2)
+            chunk_bind_rows = max(1, chunk_bind_rows)
+
+            base_inputs = self._trim_sequence_padding(self._slice_example_batch(inputs, 0, base_count))
+            _, base_logits, base_labels = self._forward_with_expanded_labels(model, base_inputs)
+            ce_loss = self._token_ce_loss_from_logits(base_logits, base_labels)
+            self._anchor_ecg_backward(ce_loss)
+            total_loss_for_log = ce_loss.detach()
+            del base_logits, base_labels, base_inputs
+
+            complete_rows, incomplete_rows = self._anchor_complete_row_indices(
+                candidate_row_index=candidate_row_index,
+                row_eligible=row_eligible,
+                row_target_answer_index=row_target_answer_index,
+                row_answer_space_size=row_answer_space_size,
+            )
+            eligible_row_count = len(complete_rows)
+            weighted_margin_for_log = ce_loss.detach() * 0.0
+            margin_loss_for_log = ce_loss.detach() * 0.0
+            stats_accum = {
+                "anchor_target_score_sum": 0.0,
+                "anchor_best_wrong_score_sum": 0.0,
+                "anchor_target_margin_sum": 0.0,
+                "anchor_positive_margin_count": 0.0,
+                "anchor_negative_margin_count": 0.0,
+                "anchor_margin_violation_count": 0.0,
+                "anchor_margin_row_count": 0.0,
+            }
+            margin_chunk_count = 0
+
+            # DeepSpeed expects the same backward-call structure on every rank.
+            # Avoid collectives between split backwards; use the configured
+            # microbatch upper bound so ranks with fewer eligible rows emit
+            # zero-loss backwards in the same slots.
+            static_row_bound = max(
+                int(base_count),
+                int(getattr(self.args, "per_device_train_batch_size", 0) or 0),
+                int(row_answer_space_size.numel()) if torch.is_tensor(row_answer_space_size) else 0,
+            )
+            global_margin_chunk_count = (static_row_bound + chunk_bind_rows - 1) // chunk_bind_rows
+
+            for chunk_idx in range(global_margin_chunk_count):
+                row_start = chunk_idx * chunk_bind_rows
+                chunk_rows = complete_rows[row_start:row_start + chunk_bind_rows] if row_start < eligible_row_count else []
+                if not chunk_rows:
+                    self._anchor_ecg_backward(self._anchor_ecg_zero_trainable_loss(model))
+                    margin_chunk_count += 1
+                    continue
+                row_mask = torch.zeros_like(candidate_row_index, dtype=torch.bool)
+                for row_idx in chunk_rows:
+                    row_mask |= candidate_row_index == row_idx
+                candidate_local_indices = row_mask.nonzero(as_tuple=False).flatten()
+                if candidate_local_indices.numel() == 0:
+                    self._anchor_ecg_backward(self._anchor_ecg_zero_trainable_loss(model))
+                    margin_chunk_count += 1
+                    continue
+                overall_indices = candidate_local_indices + base_count
+                chunk_inputs = self._trim_sequence_padding(
+                    self._index_select_example_batch(inputs, overall_indices)
+                )
+                _, candidate_logits, candidate_labels = self._forward_with_expanded_labels(model, chunk_inputs)
+                candidate_losses = self._sequence_losses_from_logits_with_normalization(
+                    candidate_logits,
+                    candidate_labels,
+                    length_normalize=length_normalize,
+                )
+                candidate_scores = -candidate_losses
+                chunk_candidate_row_index = candidate_row_index.index_select(0, candidate_local_indices.to(candidate_row_index.device))
+                chunk_candidate_answer_index = candidate_answer_index.index_select(0, candidate_local_indices.to(candidate_answer_index.device))
+                chunk_loss_sum, chunk_stats = self._anchor_margin_loss_sum_for_rows(
+                    candidate_scores,
+                    candidate_row_index=chunk_candidate_row_index,
+                    candidate_answer_index=chunk_candidate_answer_index,
+                    row_target_answer_index=row_target_answer_index,
+                    row_answer_space_size=row_answer_space_size,
+                    row_indices=chunk_rows,
+                )
+                chunk_loss = lambda_margin * chunk_loss_sum / float(eligible_row_count)
+                self._anchor_ecg_backward(chunk_loss)
+                weighted_margin_for_log = weighted_margin_for_log + chunk_loss.detach()
+                margin_loss_for_log = margin_loss_for_log + (chunk_loss_sum.detach() / float(eligible_row_count))
+                margin_chunk_count += 1
+                for key, value in chunk_stats.items():
+                    if torch.is_tensor(value):
+                        value = float(value.detach().float().cpu().item())
+                    stats_accum[key] += float(value)
+                del (
+                    candidate_logits,
+                    candidate_labels,
+                    candidate_losses,
+                    candidate_scores,
+                    chunk_inputs,
+                    chunk_candidate_row_index,
+                    chunk_candidate_answer_index,
+                    chunk_loss,
+                    chunk_loss_sum,
+                )
+
+            total_loss_for_log = total_loss_for_log + weighted_margin_for_log
+            row_count_for_stats = max(stats_accum["anchor_margin_row_count"], 1.0)
+            extra_metrics = {
+                "anchor_ecg_lambda_margin": lambda_margin,
+                "anchor_ecg_margin_delta": float(getattr(data_args, "anchor_ecg_margin_delta", 0.5)),
+                "anchor_ecg_length_normalize": int(length_normalize),
+                "anchor_ecg_memory_safe_backward": 1,
+                "anchor_ecg_margin_chunk_bind_rows": chunk_bind_rows,
+                "anchor_margin_chunk_count": margin_chunk_count,
+                "anchor_eligible_rows_in_batch": float(eligible_row_count),
+                "anchor_incomplete_rows_in_batch": float(incomplete_rows),
+                "anchor_target_score_mean": stats_accum["anchor_target_score_sum"] / row_count_for_stats,
+                "anchor_best_wrong_score_mean": stats_accum["anchor_best_wrong_score_sum"] / row_count_for_stats,
+                "anchor_target_margin_mean": stats_accum["anchor_target_margin_sum"] / row_count_for_stats,
+                "anchor_target_margin_positive_rate": stats_accum["anchor_positive_margin_count"] / row_count_for_stats,
+                "anchor_target_margin_negative_rate": stats_accum["anchor_negative_margin_count"] / row_count_for_stats,
+                "anchor_margin_violation_rate": stats_accum["anchor_margin_violation_count"] / row_count_for_stats,
+            }
+            self._write_anchor_debug_row(
+                loss=total_loss_for_log,
+                ce_loss=ce_loss.detach(),
+                margin_loss=margin_loss_for_log,
+                weighted_margin=weighted_margin_for_log,
+                base_count=base_count,
+                candidate_count=candidate_count,
+                skipped_count=skipped_count,
+                extra_metrics=extra_metrics,
+            )
+            return total_loss_for_log.detach() / self.args.gradient_accumulation_steps
+
+    def training_step(self, model: nn.Module, inputs) -> torch.Tensor:
+        data_args = self._triplet_data_args()
+        anchor_enabled = bool(
+            data_args is not None
+            and (getattr(data_args, "anchor_ecg_enable", False) or getattr(data_args, "targetmargin_enable", False))
+            and getattr(data_args, "anchor_ecg_memory_safe_backward", False)
+        )
+        if anchor_enabled and inputs.get("anchor_ecg_candidate_count", None) is not None:
+            return self._anchor_ecg_memory_safe_training_step(model, inputs)
+        return super().training_step(model, inputs)
+
+    def compute_loss(self, model, inputs, return_outputs=False, **kwargs):
+        triplet_group_size = inputs.pop("triplet_group_size", None)
+        triplet_num_groups = inputs.pop("triplet_num_groups", None)
+        if triplet_group_size is None:
+            anchor_candidate_count = inputs.get("anchor_ecg_candidate_count", None)
+            data_args = self._triplet_data_args()
+            anchor_enabled = bool(
+                getattr(data_args, "anchor_ecg_enable", False)
+                or getattr(data_args, "targetmargin_enable", False)
+            )
+            if anchor_enabled and anchor_candidate_count is not None:
+                return self._compute_anchor_ecg_rowwise_loss(model, inputs, return_outputs=return_outputs, **kwargs)
+            for key in (
+                "anchor_ecg_base_count",
+                "anchor_ecg_candidate_count",
+                "anchor_ecg_candidate_row_index",
+                "anchor_ecg_candidate_answer_index",
+                "anchor_ecg_row_eligible",
+                "anchor_ecg_row_target_answer_index",
+                "anchor_ecg_row_answer_space_size",
+                "anchor_ecg_rows_skipped",
+            ):
+                inputs.pop(key, None)
+            return super().compute_loss(model, inputs, return_outputs=return_outputs, **kwargs)
+
+        retention_num_samples_tensor = inputs.pop("retention_num_samples", None)
+        candidate_count_tensor = inputs.pop("layoutbind_candidate_count", None)
+
+        candidate_group_index = inputs.pop("layoutbind_candidate_group_index", None)
+        candidate_layout_index = inputs.pop("layoutbind_candidate_layout_index", None)
+        candidate_answer_index = inputs.pop("layoutbind_candidate_answer_index", None)
+        group_eligible = inputs.pop("layoutbind_group_eligible", None)
+        group_target_answer_index = inputs.pop("layoutbind_group_target_answer_index", None)
+        group_answer_space_size = inputs.pop("layoutbind_group_answer_space_size", None)
+
+        if torch.is_tensor(triplet_group_size):
+            triplet_group_size = int(triplet_group_size.detach().cpu().item())
+        else:
+            triplet_group_size = int(triplet_group_size)
+        if torch.is_tensor(triplet_num_groups):
+            triplet_num_groups = int(triplet_num_groups.detach().cpu().item())
+        else:
+            triplet_num_groups = int(triplet_num_groups)
+
+        expected = triplet_num_groups * triplet_group_size
+        retention_num_samples = 0
+        if retention_num_samples_tensor is not None:
+            retention_num_samples = int(retention_num_samples_tensor.detach().cpu().item())
+        candidate_count = 0
+        if candidate_count_tensor is not None:
+            candidate_count = int(candidate_count_tensor.detach().cpu().item())
+        total_expected = expected + retention_num_samples + candidate_count
+        data_args = self._triplet_data_args()
+        candidate_chunk_size = int(getattr(data_args, "layoutbind_candidate_chunk_size", 0) or 0)
+        if candidate_chunk_size > 0:
+            raise RuntimeError(
+                "layoutbind_candidate_chunk_size > 0 is currently disabled. "
+                "The prototype preserves the loss but DeepSpeed ZeRO-2 reduces the same LoRA "
+                "parameters multiple times when multiple forward graphs are backpropagated in "
+                "one training_step. Use 0 for the supported exact LayoutBind path."
+            )
+        outputs, sequence_losses, model_forward_calls = self._forward_sequence_losses_with_candidate_chunks(
+            model,
+            inputs,
+            base_count=expected + retention_num_samples,
+            candidate_count=candidate_count,
+            candidate_chunk_size=candidate_chunk_size,
+        )
+        if sequence_losses.numel() != total_expected:
+            raise ValueError(
+                f"Grouped triplet loss expected {total_expected} flattened examples "
+                f"({expected} triplet + {retention_num_samples} retention + {candidate_count} candidates), "
+                f"got {sequence_losses.numel()}."
+            )
+
+        triplet_sequence_losses = sequence_losses[:expected]
+        retention_sequence_losses = sequence_losses[expected:expected + retention_num_samples]
+        candidate_sequence_losses = sequence_losses[expected + retention_num_samples:]
+
+        layout_losses = triplet_sequence_losses.view(triplet_num_groups, triplet_group_size).mean(dim=0)
+        group_losses = triplet_sequence_losses.view(triplet_num_groups, triplet_group_size).mean(dim=1)
+        bind_ce_loss = group_losses.mean()
+        retention_loss = (
+            retention_sequence_losses.mean()
+            if retention_sequence_losses.numel() > 0
+            else sequence_losses.sum() * 0.0
+        )
+
+        bind_view_count = torch.tensor(float(triplet_sequence_losses.numel()), device=sequence_losses.device, dtype=sequence_losses.dtype)
+        retention_view_count = torch.tensor(float(retention_num_samples), device=sequence_losses.device, dtype=sequence_losses.dtype)
+        loss = (
+            bind_ce_loss * bind_view_count + retention_loss * retention_view_count
+        ) / (bind_view_count + retention_view_count).clamp_min(1.0)
+        mixed_ce_loss = loss
+        layoutbind_enabled = bool(getattr(data_args, "layoutbind_enable", False))
+        bind_loss = sequence_losses.sum() * 0.0
+        margin_loss = sequence_losses.sum() * 0.0
+        layoutbind_stats = {
+            "target_score_mean": bind_loss.detach(),
+            "best_wrong_score_mean": bind_loss.detach(),
+            "target_margin_mean": bind_loss.detach(),
+            "target_margin_positive_rate": bind_loss.detach(),
+            "target_margin_negative_rate": bind_loss.detach(),
+            "margin_violation_rate": bind_loss.detach(),
+            "kl_bind_loss_mean": bind_loss.detach(),
+            "layoutbind_eligible_groups_in_batch": 0.0,
+        }
+        if (
+            layoutbind_enabled
+            and candidate_sequence_losses.numel() > 0
+            and candidate_group_index is not None
+            and candidate_layout_index is not None
+            and candidate_answer_index is not None
+            and group_target_answer_index is not None
+            and group_answer_space_size is not None
+        ):
+            candidate_scores = -candidate_sequence_losses
+            bind_loss, margin_loss, layoutbind_stats = self._layoutbind_losses(
+                candidate_scores,
+                candidate_group_index=candidate_group_index,
+                candidate_layout_index=candidate_layout_index,
+                candidate_answer_index=candidate_answer_index,
+                group_eligible=group_eligible,
+                group_target_answer_index=group_target_answer_index,
+                group_answer_space_size=group_answer_space_size,
+                group_size=triplet_group_size,
+            )
+            loss = (
+                loss
+                + float(getattr(data_args, "layoutbind_lambda_bind", 0.05)) * bind_loss
+                + float(getattr(data_args, "layoutbind_lambda_margin", 0.02)) * margin_loss
+            )
+        lambda_bind = float(getattr(data_args, "layoutbind_lambda_bind", 0.05))
+        lambda_margin = float(getattr(data_args, "layoutbind_lambda_margin", 0.02))
+        self._write_triplet_debug_row(
+            loss=loss,
+            layout_losses=layout_losses,
+            triplet_num_groups=triplet_num_groups,
+            triplet_group_size=triplet_group_size,
+            retention_num_samples=retention_num_samples,
+            extra_metrics={
+                "bind_ce_loss": bind_ce_loss.detach(),
+                "retention_loss": retention_loss.detach(),
+                "mixed_ce_loss": mixed_ce_loss.detach(),
+                "L_TargetBind_raw": bind_loss.detach(),
+                "weighted_TargetBind": (lambda_bind * bind_loss).detach(),
+                "L_TargetMargin_raw": margin_loss.detach(),
+                "weighted_TargetMargin": (lambda_margin * margin_loss).detach(),
+                "layoutbind_candidate_examples": float(candidate_count),
+                "layoutbind_candidate_chunk_size": float(candidate_chunk_size),
+                "layoutbind_model_forward_calls": float(model_forward_calls),
+                **layoutbind_stats,
+            },
+        )
+        return (loss, outputs) if return_outputs else loss
+
