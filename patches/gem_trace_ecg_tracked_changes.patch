+def _first_human_turn(conversations: Sequence[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
+    for conv in conversations or []:
+        role = conv.get("from") or conv.get("role")
+        if role in ("human", "user"):
+            return copy.deepcopy(conv)
+    return None
+
