+def _load_image_tensor(sample: Dict[str, Any], data_args: DataArguments, model_config):
+    image_file = sample['image']
+    image_folder = data_args.image_folder
+    processor = data_args.image_processor
+    image = Image.open(os.path.join(image_folder, image_file)).convert('RGB')
+    image_size = image.size
+    assert data_args.image_aspect_ratio in ['pad', 'anyres', 'ori']
+    if data_args.image_aspect_ratio == 'pad':
+        def expand2square(pil_img, background_color):
+            width, height = pil_img.size
+            if width == height:
+                return pil_img
+            elif width > height:
+                result = Image.new(pil_img.mode, (width, width), background_color)
+                result.paste(pil_img, (0, (width - height) // 2))
+                return result
+            else:
+                result = Image.new(pil_img.mode, (height, height), background_color)
+                result.paste(pil_img, ((height - width) // 2, 0))
+                return result
+        image = expand2square(image, tuple(int(x*255) for x in processor.image_mean))
+        image = processor.preprocess(image, return_tensors='pt')['pixel_values'][0]
+    elif data_args.image_aspect_ratio == 'anyres':
+        image = process_anyres_image(image, processor, model_config.image_grid_pinpoints)
+    else:
+        image = processor.preprocess(image, return_tensors='pt')['pixel_values'][0]
+    return image, image_size
