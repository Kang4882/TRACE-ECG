+def _candidate_conversation_with_answer(
+    conversations: Sequence[Dict[str, Any]],
+    candidate_answer: str,
+) -> Optional[List[Dict[str, Any]]]:
+    """Preserve prompt context and replace only the first assistant answer."""
+    output = []
+    for conv in conversations or []:
+        copied = copy.deepcopy(conv)
+        role = copied.get("from") or copied.get("role")
+        if role in ("gpt", "assistant"):
+            if "value" in copied:
+                copied["value"] = str(candidate_answer)
+            else:
+                copied["content"] = str(candidate_answer)
+            output.append(copied)
+            return output
+        output.append(copied)
+
+    human_conv = _first_human_turn(conversations)
+    if human_conv is None:
+        return None
+    return [human_conv, {"from": "gpt", "value": str(candidate_answer)}]
+
