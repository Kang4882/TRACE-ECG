+class SaveAtRatiosCallback(transformers.TrainerCallback):
+    def __init__(self, ratios: Sequence[float]):
+        self.ratios = sorted(set(float(r) for r in ratios if 0 < float(r) < 1))
+        self.save_steps = []
+        self.triggered = set()
+
+    def on_train_begin(self, args, state, control, **kwargs):
+        max_steps = int(getattr(state, "max_steps", 0) or 0)
+        if max_steps <= 0:
+            rank0_print("GEM_SAVE_RATIOS ignored because max_steps is unavailable.")
+            return control
+        self.save_steps = sorted(
+            set(max(1, min(max_steps - 1, int(math.ceil(r * max_steps)))) for r in self.ratios)
+        )
+        rank0_print(
+            f"GEM_SAVE_RATIOS active: ratios={self.ratios}, "
+            f"max_steps={max_steps}, save_steps={self.save_steps}"
+        )
+        return control
+
+    def on_step_end(self, args, state, control, **kwargs):
+        step = int(getattr(state, "global_step", 0) or 0)
+        if step in self.save_steps and step not in self.triggered:
+            self.triggered.add(step)
+            rank0_print(f"GEM_SAVE_RATIOS triggering checkpoint save at step {step}.")
+            control.should_save = True
+        return control
+
+
+def parse_save_ratios_from_env() -> List[float]:
+    raw = os.environ.get("GEM_SAVE_RATIOS", "").strip()
+    if not raw:
+        return []
+    ratios = []
+    for item in raw.split(","):
+        item = item.strip()
+        if not item:
+            continue
+        try:
+            value = float(item)
+        except ValueError:
+            rank0_print(f"Ignoring invalid GEM_SAVE_RATIOS item: {item!r}")
+            continue
+        if 0 < value < 1:
+            ratios.append(value)
+        else:
+            rank0_print(f"Ignoring out-of-range GEM_SAVE_RATIOS item: {item!r}")
+    return ratios
+
