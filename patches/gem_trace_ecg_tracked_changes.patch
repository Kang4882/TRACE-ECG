+def _answer_candidates_from_metadata(metadata: Dict[str, Any]) -> List[str]:
+    raw = metadata.get("candidate_answers")
+    if raw is None:
+        raw = metadata.get("candidate_answer_strings")
+    if isinstance(raw, str):
+        try:
+            raw = json.loads(raw)
+        except json.JSONDecodeError:
+            raw = [part.strip() for part in raw.split("|")]
+    if not isinstance(raw, (list, tuple)):
+        return []
+    candidates = []
+    seen = set()
+    for value in raw:
+        text = str(value).strip()
+        key = text.lower()
+        if text and key not in seen:
+            candidates.append(text)
+            seen.add(key)
+    return candidates
+
